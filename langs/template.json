    },
    "utilities": {
      "name": "Utilities",
      "commands": {
        "weather": { "cmd": "curl -s wttr.in/{}", "description": "Description here", "args": 1 },
        "translate": { "cmd": "trans '{}'", "description": "Description here", "args": 1 },
        "timer": { "cmd": "sleep {} && paplay /usr/share/sounds/freedesktop/complete.oga", "description": "Description here", "args": 1 },
        "notes": { "cmd": "$EDITOR ~/ka_notes.txt", "description": "Description here", "args": 0 },
        "todo": { "cmd": "cat ~/ka_todo.txt", "description": "Description here", "args": 0 },
        "todo add": { "cmd": "echo {} >> ~/ka_todo.txt", "description": "Description here", "args": 1 },
        "screenshot": { "cmd": "gnome-screenshot -i", "description": "Description here", "args": 0 },
        "clipboard copy": { "cmd": "echo {} | xclip -selection clipboard", "description": "Description here", "args": 1 },
        "clipboard paste": { "cmd": "xclip -selection clipboard -o", "description": "Description here", "args": 0 },
        "clear": { "cmd": "clear", "description": "Description here", "args": 0 },
        "echo": { "cmd": "echo {}", "description": "Description here", "args": 1 }

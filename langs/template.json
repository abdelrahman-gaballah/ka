{
  "language": "TEMPLATE",
  "name": "Template Language",
  "categories": {
    "system_info": {
      "name": "System Information",
      "commands": {
        "space": { "cmd": "df -h", "description": "Description here", "args": 0 },
        "ram": { "cmd": "free -h", "description": "Description here", "args": 0 },
        "cpu": { "cmd": "top -bn1 | grep 'Cpu(s)'", "description": "Description here", "args": 0 },
        "battery": { "cmd": "upower -i $(upower -e | grep BAT) | grep -E 'percentage|to empty'", "description": "Description here", "args": 0 },
        "uptime": { "cmd": "uptime -p", "description": "Description here", "args": 0 },
        "os": { "cmd": "cat /etc/os-release | grep PRETTY_NAME | cut -d= -f2", "description": "Description here", "args": 0 },
        "kernel": { "cmd": "uname -r", "description": "Description here", "args": 0 },
        "users": { "cmd": "who", "description": "Description here", "args": 0 },
        "date": { "cmd": "date", "description": "Description here", "args": 0 },
        "calendar": { "cmd": "cal", "description": "Description here", "args": 0 },
        "temperature": { "cmd": "sensors | grep 'Core 0'", "description": "Description here", "args": 0 }
      }
    },
    "file_operations": {
      "name": "File Operations",
      "commands": {
        "list": { "cmd": "ls -la", "description": "Description here", "args": 0 },
        "list large": { "cmd": "ls -laS", "description": "Description here", "args": 0 },
        "list recent": { "cmd": "ls -lat", "description": "Description here", "args": 0 },
        "tree": { "cmd": "tree", "description": "Description here", "args": 0 },
        "copy": { "cmd": "cp -r {} {}", "description": "Description here", "args": 2 },
        "move": { "cmd": "mv {} {}", "description": "Description here", "args": 2 },
        "delete": { "cmd": "rm -i {}", "description": "Description here", "args": 1 },
        "create folder": { "cmd": "mkdir -p {}", "description": "Description here", "args": 1 },
        "create file": { "cmd": "touch {}", "description": "Description here", "args": 1 },
        "rename": { "cmd": "mv {} {}", "description": "Description here", "args": 2 },
        "open folder": { "cmd": "xdg-open {}", "description": "Description here", "args": 1 },
        "zip": { "cmd": "zip -r {}.zip {}", "description": "Description here", "args": 2 },
        "unzip": { "cmd": "unzip {}", "description": "Description here", "args": 1 },
        "tar compress": { "cmd": "tar -czvf {}.tar.gz {}", "description": "Description here", "args": 2 },
        "tar extract": { "cmd": "tar -xzvf {}", "description": "Description here", "args": 1 },
        "find name": { "cmd": "find . -name {}", "description": "Description here", "args": 1 },
        "find text": { "cmd": "grep -r {} .", "description": "Description here", "args": 1 }
      }
    },
    "network": {
      "name": "Network",
      "commands": {
        "ip": { "cmd": "ip -br a", "description": "Description here", "args": 0 },
        "ip public": { "cmd": "curl -s ifconfig.me", "description": "Description here", "args": 0 },
        "wifi": { "cmd": "nmcli device wifi list", "description": "Description here", "args": 0 },
        "wifi connect": { "cmd": "nmcli device wifi connect {} password {}", "description": "Description here", "args": 2 },
        "ping": { "cmd": "ping -c 4 {}", "description": "Description here", "args": 1 },
        "ports": { "cmd": "ss -tuln", "description": "Description here", "args": 0 },
        "firewall status": { "cmd": "sudo ufw status", "description": "Description here", "args": 0 },
        "download": { "cmd": "wget {}", "description": "Description here", "args": 1 },
        "speedtest": { "cmd": "speedtest-cli", "description": "Description here", "args": 0 }
      }
    },
    "system_control": {
      "name": "System Control",
      "commands": {
        "shutdown": { "cmd": "shutdown now", "description": "Description here", "args": 0 },
        "shutdown time": { "cmd": "shutdown +{}", "description": "Description here", "args": 1 },
        "restart": { "cmd": "reboot", "description": "Description here", "args": 0 },
        "suspend": { "cmd": "systemctl suspend", "description": "Description here", "args": 0 },
        "lock": { "cmd": "loginctl lock-session", "description": "Description here", "args": 0 },
        "update": { "cmd": "sudo apt update && sudo apt upgrade -y", "description": "Description here", "args": 0 },
        "clean": { "cmd": "sudo apt autoremove -y && sudo apt autoclean", "description": "Description here", "args": 0 },
        "brightness up": { "cmd": "brightnessctl set +10%", "description": "Description here", "args": 0 },
        "brightness down": { "cmd": "brightnessctl set 10%-", "description": "Description here", "args": 0 },
        "volume up": { "cmd": "pactl set-sink-volume @DEFAULT_SINK@ +5%", "description": "Description here", "args": 0 },
        "volume down": { "cmd": "pactl set-sink-volume @DEFAULT_SINK@ -5%", "description": "Description here", "args": 0 },
        "mute": { "cmd": "pactl set-sink-mute @DEFAULT_SINK@ toggle", "description": "Description here", "args": 0 }
      }
    },
    "processes": {
      "name": "Process Management",
      "commands": {
        "processes": { "cmd": "ps aux", "description": "Description here", "args": 0 },
        "top": { "cmd": "top", "description": "Description here", "args": 0 },
        "kill": { "cmd": "kill {}", "description": "Description here", "args": 1 },
        "kill name": { "cmd": "pkill {}", "description": "Description here", "args": 1 },
        "memory hog": { "cmd": "ps aux --sort=-%mem | head -10", "description": "Description here", "args": 0 },
        "cpu hog": { "cmd": "ps aux --sort=-%cpu | head -10", "description": "Description here", "args": 0 },
        "service status": { "cmd": "systemctl status {}", "description": "Description here", "args": 1 },
        "service start": { "cmd": "sudo systemctl start {}", "description": "Description here", "args": 1 },
        "service stop": { "cmd": "sudo systemctl stop {}", "description": "Description here", "args": 1 },
        "service restart": { "cmd": "sudo systemctl restart {}", "description": "Description here", "args": 1 }
      }
    },
    "development": {
      "name": "Development",

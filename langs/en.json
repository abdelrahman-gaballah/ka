{
  "language": "en",
  "name": "English",
  "categories": {
    "system_info": {
      "name": "System Information",
      "commands": {
        "space": { "cmd": "df -h", "description": "Show disk space usage", "args": 0 },
        "space inode": { "cmd": "df -i", "description": "Show inode usage", "args": 0 },
        "space here": { "cmd": "du -sh .", "description": "Show current directory size", "args": 0 },
        "space folder": { "cmd": "du -sh {}", "description": "Show folder size", "args": 1 },
        "ram": { "cmd": "free -h", "description": "Show RAM usage", "args": 0 },
        "ram detailed": { "cmd": "free -h -t", "description": "Show RAM with total", "args": 0 },
        "cpu": { "cmd": "top -bn1 | grep 'Cpu(s)'", "description": "Show CPU usage", "args": 0 },
        "cpu cores": { "cmd": "nproc", "description": "Show number of CPU cores", "args": 0 },
        "cpu info": { "cmd": "lscpu | grep 'Model name'", "description": "Show CPU model", "args": 0 },
        "battery": { "cmd": "upower -i $(upower -e | grep BAT) | grep -E 'percentage|to empty'", "description": "Show battery status", "args": 0 },
        "battery full": { "cmd": "upower -i $(upower -e | grep BAT) | grep -E 'percentage|to full'", "description": "Show time to full charge", "args": 0 },
        "uptime": { "cmd": "uptime -p", "description": "Show uptime pretty", "args": 0 },
        "uptime raw": { "cmd": "uptime", "description": "Show uptime raw", "args": 0 },
        "os": { "cmd": "cat /etc/os-release | grep PRETTY_NAME | cut -d= -f2", "description": "Show OS name", "args": 0 },
        "kernel": { "cmd": "uname -r", "description": "Show kernel version", "args": 0 },
        "users": { "cmd": "who", "description": "Show logged in users", "args": 0 },
        "date": { "cmd": "date", "description": "Show current date and time", "args": 0 },
        "calendar": { "cmd": "cal", "description": "Show calendar", "args": 0 },
        "calendar year": { "cmd": "cal {}", "description": "Show year calendar", "args": 1 },
        "temperature": { "cmd": "sensors | grep 'Core 0'", "description": "Show CPU temperature", "args": 0 },
        "disk health": { "cmd": "sudo smartctl -H /dev/sda", "description": "Check disk health", "args": 0 }
      }
    },
    "file_operations": {
      "name": "File Operations",
      "commands": {
        "list": { "cmd": "ls -la", "description": "List all files", "args": 0 },
